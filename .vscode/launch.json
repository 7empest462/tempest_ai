{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch Tempest Extension",
            "type": "extensionHost",
            "request": "launch",
            "runtimeExecutable": "${execPath}",
            "args": [
                "--extensionDevelopmentPath=${workspaceFolder}/vscode-tempest"
            ],
            "outFiles": [
                "${workspaceFolder}/vscode-tempest/out/**/*.js"
            ],
            "preLaunchTask": "npm: compile"
        }
    ]
}
