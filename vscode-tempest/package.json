{
    "name": "vscode-tempest",
    "displayName": "Tempest AI",
    "description": "Hardware-Aware Autonomous Engineering Assistant",
    "version": "0.3.7",
    "license": "SEE LICENSE IN ROOT",
    "engines": {
        "vscode": "^1.90.0"
    },
    "categories": [
        "Programming Languages",
        "AI"
    ],
    "main": "./out/extension.js",
    "activationEvents": [
        "onView:tempest.chatView"
    ],
    "contributes": {
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "tempest-sidebar",
                    "title": "Tempest AI",
                    "icon": "resources/icon.svg"
                }
            ]
        },
        "views": {
            "tempest-sidebar": [
                {
                    "type": "webview",
                    "id": "tempest.chatView",
                    "name": "Tempest Chat",
                    "icon": "resources/icon.svg"
                }
            ]
        },
        "commands": [
            {
                "command": "tempest.focus",
                "title": "Tempest: Focus Sidebar"
            },
            {
                "command": "tempest.clearHistory",
                "title": "Tempest AI: Clear History"
            }
        ]
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "lint": "eslint src --ext .ts --fix",
        "format": "prettier --write src",
        "format:check": "prettier --check src",
        "lint:fix": "npm run lint && npm run format",
        "check": "npm run format:check && npm run lint"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/node": "^20.0.0",
        "@types/vscode": "^1.90.0",
        "@typescript-eslint/eslint-plugin": "^8.61.1",
        "@typescript-eslint/parser": "^8.61.1",
        "eslint": "^10.5.0",
        "eslint-config-prettier": "^10.1.8",
        "prettier": "^3.8.4",
        "typescript": "^5.4.5",
        "typescript-eslint": "^8.61.1"
    }
}
